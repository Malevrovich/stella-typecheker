INPUT:
// Nested match: ERROR_UNEXPECTED_PATTERN_FOR_TYPE
// inner match uses inl/inr patterns on a non-sum type (Nat)
language core;
extend with #sum-types;

fn main(x : Nat + Bool) -> Nat {
  return match x {
      inl(n) => match n {
          inl(k) => k    // n is Nat, not a sum type
        | inr(b) => 0
      }
    | inr(b) => if b then 1 else 0
  }
}


