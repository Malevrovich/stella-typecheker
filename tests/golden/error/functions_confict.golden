// программа на Stella
language core;

fn increment_twice(n : Nat)-> Nat {
    return succ(succ(n))
}

fn increment_twice(n : Nat)-> Nat {
    return succ(n)
}

// наличие main обязательно
fn main(n : Nat)-> Nat {
    return increment_twice( if Nat::iszero(n) then false else true )
}

